    "import numpy as np\n",
    "\n",
    "def differentiate_vector(vector, e):\n",
    "\n",
    "    gamma, gamma_tilde, omega, omega_tilde = vector_to_matrices(vector)\n",
    "\n",
    "    N_tilde = np.linalg.inv(np.identity(2) - gamma_tilde @ gamma)\n",
    "    N = np.linalg.inv(np.identity(2) - gamma @ gamma_tilde)\n",
    "\n",
    "    d_dx_gamma = omega\n",
    "    d_dx_gamma_tilde = omega_tilde\n",
    "\n",
    "    d_dx_omega = -2j*(e+0.01j)*gamma - 2 * omega @ N_tilde @ gamma_tilde @ omega\n",
    "    d_dx_omega_tilde = -2j*(e+0.01j)*gamma_tilde - 2 * omega_tilde @ N @ gamma @ omega_tilde\n",
    "\n",
    "    differentiated = matrices_to_vector(\n",
    "        d_dx_gamma,\n",
    "        d_dx_gamma_tilde,\n",
    "        d_dx_omega,\n",
    "        d_dx_omega_tilde\n",
    "    )\n",
    "\n",
    "    return differentiated\n",
    "\n",
