    "def split_vector(v): # Splitter opp en 32 lang vektor til 4 små som er 8 lange\n",
    "    m1 = np.array(v[0:8])\n",
    "    m2 = np.array(v[8:16])\n",
    "    m3 = np.array(v[16:24])\n",
    "    m4 = np.array(v[24:32])\n",
    "    return m1, m2, m3 ,m4\n",
